# Supabase — Phase 3.
# Copy this file to .env.local and fill in the real values from your Supabase
# project (Dashboard → Project Settings → API). .env.local is gitignored
# (*.local), so secrets never get committed.
#
# The anon key is PUBLIC by design — Row-Level Security guards the data.
# NEVER put the service_role key in here; it bypasses RLS.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Tester pass-through (device testing BEFORE App Store Connect products exist):
# build with VITE_TESTER=1 and the paywall's plans grant a mock trial instead of
# billing, so the coach-gated surfaces (Guardian, weekly review, counsel) are
# walkable on a phone. NEVER set this for a store build.
# VITE_TESTER=1
